{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@neutrino/tokens": ["../../packages/tokens/src/index.css"],
      "@neutrino/ui": ["../../packages/ui/src/index.ts"],
      "@neutrino/ui/styles": ["../../packages/ui/src/styles/index.css"],
      "@neutrino/layout": ["../../packages/layout/src/index.ts"],
      "@neutrino/auth": ["../../packages/auth/src/index.ts"],
      "@neutrino/api-core": ["../../packages/api-core/src/index.ts"],
      "@neutrino/api-drive": ["../../packages/api-drive/src/index.ts"],
      "@neutrino/api-docs": ["../../packages/api-docs/src/index.ts"],
      "@neutrino/api-sheets": ["../../packages/api-sheets/src/index.ts"],
      "@neutrino/api-slides": ["../../packages/api-slides/src/index.ts"],
      "@neutrino/api-photos": ["../../packages/api-photos/src/index.ts"],
      "@neutrino/api-notes": ["../../packages/api-notes/src/index.ts"],
      "@neutrino/sheet-embed": ["../../packages/sheet-embed/src/index.ts"],
      "@neutrino/hooks": ["../../packages/hooks/src/index.ts"],
      "@neutrino/utils": ["../../packages/utils/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
